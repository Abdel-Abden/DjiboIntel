# ═══════════════════════════════════════════════════
#  DjiboIntel Backend — Variables d'environnement
#  Copiez ce fichier en ".env" et remplissez les valeurs
#  NE JAMAIS commiter le fichier .env dans git !
# ═══════════════════════════════════════════════════

# ── PORT DU SERVEUR ──────────────────────────────
PORT=3001

# ── CLÉS API ─────────────────────────────────────

# NewsAPI — https://newsapi.org (gratuit jusqu'à 100 req/jour)
NEWSAPI_KEY=d3f6d030274d4d62b7c5245b8300a22c

# Alpha Vantage — https://www.alphavantage.co (gratuit)
ALPHAVANTAGE_KEY=1SS7FEV5HOLYE2OK

# MarineTraffic AIS — https://marinetraffic.com (Phase 2 — payant)
# Laissez vide pour désactiver la route /api/maritime/ais
MARINETRAFFIC_KEY=

# ── SÉCURITÉ ─────────────────────────────────────

# Origines autorisées à appeler l'API (séparées par virgule)
# En production : mettez exactement l'URL Netlify de votre frontend
# Exemple : https://djibointel.netlify.app,https://djibointel.dj
# En développement : * pour tout autoriser
ALLOWED_ORIGINS=*

# Token optionnel pour restreindre l'accès à l'API
# Si défini, le frontend doit envoyer x-api-token: <valeur>
# Laissez vide pour accès public
API_TOKEN=

# Secret pour vider le cache (DELETE /api/cache)
ADMIN_SECRET=changez-moi-en-production
